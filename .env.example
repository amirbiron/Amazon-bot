# Amazon Creators API
CREATORS_API_CREDENTIAL_ID=your_credential_id_here
CREATORS_API_CREDENTIAL_SECRET=your_credential_secret_here
CREATORS_API_VERSION=2.1         # 2.1 = NA (US/CA/BR/MX), 2.2 = EU, 2.3 = FE (JP/AU/SG)

# Amazon Associates partner tag (e.g. yoursite-20)
PAAPI_PARTNER_TAG=yoursite-20

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-1001234567890   # channel: negative number | private chat: positive number

# Timing (optional — defaults shown)
CHECK_INTERVAL_SECONDS=360        # 6 minutes
CATALOG_REFRESH_HOURS=8

# Filters (optional — defaults shown)
MAX_PRICE_USD=180

# DB path (optional — SQLite default)
DB_PATH=bot.db
